    "@tiptap/react": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "@tiptap/suggestion": "^2.10.0",
    "@types/dagre": "^0.7.54",
    "@types/leaflet": "^1.9.21",
    "dagre": "^0.8.5",
    "leaflet": "^1.9.4",
    "openapi-fetch": "^0.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "zustand": "^5.0.2"
