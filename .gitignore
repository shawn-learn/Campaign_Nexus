# Python
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Local database + WAL sidecars (never commit campaign data)
*.db
*.db-wal
*.db-shm

# Uploaded media (map images, handouts) — user content, not source
backend/media/

# Automatic DB + media snapshots — local runtime data, not source
backend/backups/

# Node / frontend
node_modules/
frontend/dist/

# Claude Code local settings (per-machine)
.claude/settings.local.json

# Editor / OS
.DS_Store
.idea/
.vscode/
*.log

# D&D adventure content / assets — not source code
Curse of Strahd/
Curse of Strahd.md
curse-of-strahd-master/
cos/

# TypeScript incremental build info — generated
frontend/tsconfig.app.tsbuildinfo

# pytest temp dirs (permission-locked on Windows)
backend/.pytest-tmp/
backend/.pytest-tmp-verify/
backend/.pytest-tmp-verify2/
